generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SELLER
}

enum Dimension {
  WEIGHT
  VOLUME
  COUNT
}

enum OrderStatus {
  NEW
  CONFIRMED
  CANCELLED
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  name     String
  password String
  role     Role     @default(SELLER)
  orders   Order[]
}

model Product {
  id              Int       @id @default(autoincrement())
  name            String
  sku             String    @unique
  category        String
  description     String?
  dimension       Dimension
  baseUnit        String
  pricePerBase    Decimal   @db.Decimal(18,6)
  inventoryBase   Decimal   @db.Decimal(18,6)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orderItems      OrderItem[]
}

model Order {
  id           Int         @id @default(autoincrement())
  user         User        @relation(fields: [userId], references: [id])
  userId       Int
  isQuotation  Boolean     @default(false)
  status       OrderStatus @default(NEW)
  totalAmount  Decimal     @db.Decimal(18,6)
  createdAt    DateTime    @default(now())
  items        OrderItem[]
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  order           Order    @relation(fields: [orderId], references: [id])
  orderId         Int
  product         Product  @relation(fields: [productId], references: [id])
  productId       Int
  unit            String
  quantity        Decimal  @db.Decimal(18,6)
  quantityBase    Decimal  @db.Decimal(18,6)
  pricePerBase    Decimal  @db.Decimal(18,6)
  lineTotal       Decimal  @db.Decimal(18,6)
}
